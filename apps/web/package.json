{
  "name": "@operaclinic/web",
  "version": "0.1.0",
  "private": true,
  "description": "OperaClinic web panel for aesthetic clinic operations with Next.js App Router.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "node ./scripts/reset-next-generated.mjs full && next build",
    "start": "next start -p 3000",
    "typecheck": "node ./scripts/reset-next-generated.mjs && next typegen && node ./scripts/ensure-next-typegen-files.mjs && tsc --noEmit --incremental false",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "smoke:e2e": "vitest run --config vitest.smoke.config.ts",
    "test:watch": "vitest",
    "clean": "node ./scripts/reset-next-generated.mjs full"
  },
  "dependencies": {
    "@operaclinic/shared": "workspace:*",
    "lucide-react": "^0.577.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
