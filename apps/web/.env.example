NODE_ENV=production
NEXT_PUBLIC_APP_NAME=OperaClinic Web
# Required by the Next.js session proxy. Use https in production; no runtime fallback exists.
# Example: https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
# URL base da API para conexões WebSocket (sem /api/v1)
# Example: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3001
# Meta Embedded Signup — habilita o botão "Entrar com Meta Business" na página de integrações
# Obtenha em developers.facebook.com > Seu App > Configurações Básicas
NEXT_PUBLIC_META_APP_ID=
# ID de configuração do Embedded Signup criado em Meta Business > Configurações de WhatsApp
NEXT_PUBLIC_META_EMBEDDED_SIGNUP_CONFIG_ID=
