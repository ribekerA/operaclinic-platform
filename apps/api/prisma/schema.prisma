  changedByUser User?       @relation("appointment_status_changed_by", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId], map: "idx_appointment_status_history_tenant_id")
  @@index([appointmentId], map: "idx_appointment_status_history_appointment_id")
  @@index([createdAt], map: "idx_appointment_status_history_created_at")
  @@map("appointment_status_history")
}

model Waitlist {
  id                 String       @id @default(uuid()) @db.Uuid
  tenantId           String       @map("tenant_id") @db.Uuid
  patientId          String       @map("patient_id") @db.Uuid
  professionalId     String?      @map("professional_id") @db.Uuid
  consultationTypeId String?      @map("consultation_type_id") @db.Uuid
  unitId             String?      @map("unit_id") @db.Uuid
  preferredDate      DateTime?    @map("preferred_date") @db.Date
  note               String?      @db.VarChar(255)
  status             WaitlistStatus @default(OPEN)
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient          Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional     Professional?    @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  consultationType ConsultationType? @relation(fields: [consultationTypeId], references: [id], onDelete: SetNull)
  unit             Unit?            @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([tenantId], map: "idx_waitlist_tenant_id")
  @@index([patientId], map: "idx_waitlist_patient_id")
  @@index([status], map: "idx_waitlist_status")
  @@map("waitlist")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  action       String   @db.VarChar(80)
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  actorProfile String   @map("actor_profile") @db.VarChar(32)
  actorRoles   String[] @map("actor_roles")
  tenantId     String?  @map("tenant_id") @db.Uuid
  targetType   String   @map("target_type") @db.VarChar(80)
  targetId     String?  @map("target_id") @db.VarChar(80)
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actorUser User?   @relation("audit_actor_logs", fields: [actorUserId], references: [id], onDelete: SetNull)
  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([action], map: "idx_audit_logs_action")
  @@index([tenantId], map: "idx_audit_logs_tenant_id")
  @@index([actorUserId], map: "idx_audit_logs_actor_user_id")
  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Protocol Models (P1: Multi-session aesthetic procedures)
// ---------------------------------------------------------------------------

model ProcedureProtocol {
  id                        String   @id @default(uuid()) @db.Uuid
  tenantId                  String   @map("tenant_id") @db.Uuid
  consultationTypeId        String   @map("consultation_type_id") @db.Uuid
  name                      String   @db.VarChar(160)
  description               String?  @db.Text
  totalSessions             Int      @map("total_sessions")
  intervalBetweenSessionsDays Int   @map("interval_between_sessions_days")
  isActive                  Boolean  @default(true) @map("is_active")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant               Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  consultationType     ConsultationType           @relation(fields: [consultationTypeId], references: [id], onDelete: Restrict)
  patientInstances     PatientProtocolInstance[]
  sessionAppointments  ProtocolSessionAppointment[]

  @@unique([tenantId, consultationTypeId, name], map: "uq_procedure_protocols_tenant_consultation_type_name")
  @@index([tenantId], map: "idx_procedure_protocols_tenant_id")
  @@index([consultationTypeId], map: "idx_procedure_protocols_consultation_type_id")
  @@map("procedure_protocols")
}

model PatientProtocolInstance {
  id                     String   @id @default(uuid()) @db.Uuid
  tenantId               String   @map("tenant_id") @db.Uuid
  patientId              String   @map("patient_id") @db.Uuid
  procedureProtocolId    String   @map("procedure_protocol_id") @db.Uuid
  status                 PatientProtocolStatus @default(ACTIVE)
  sessionsPlanned        Int      @map("sessions_planned")
  sessionsScheduled      Int      @default(0) @map("sessions_scheduled")
  sessionsCompleted      Int      @default(0) @map("sessions_completed")
  startedAt              DateTime @default(now()) @map("started_at") @db.Timestamptz(6)
  expectedCompletionAt   DateTime? @map("expected_completion_at") @db.Timestamptz(6)
  completedAt            DateTime? @map("completed_at") @db.Timestamptz(6)
  abandonedAt            DateTime? @map("abandoned_at") @db.Timestamptz(6)
  notes                  String?  @db.Text
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant             Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient            Patient                    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  procedureProtocol  ProcedureProtocol          @relation(fields: [procedureProtocolId], references: [id], onDelete: Restrict)
  sessionAppointments ProtocolSessionAppointment[]

  @@unique([patientId, procedureProtocolId], map: "uq_patient_protocol_instances_patient_protocol")
  @@index([tenantId], map: "idx_patient_protocol_instances_tenant_id")
  @@index([patientId], map: "idx_patient_protocol_instances_patient_id")
  @@index([procedureProtocolId], map: "idx_patient_protocol_instances_procedure_protocol_id")
  @@index([status], map: "idx_patient_protocol_instances_status")
  @@map("patient_protocol_instances")
}

model ProtocolSessionAppointment {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  patientProtocolInstanceId String @map("patient_protocol_instance_id") @db.Uuid
  procedureProtocolId   String   @map("procedure_protocol_id") @db.Uuid
  appointmentId         String?  @map("appointment_id") @db.Uuid
  sessionSequence       Int      @map("session_sequence")
  status                ProtocolSessionStatus @default(PLANNED)
  plannedStartDate      DateTime @map("planned_start_date") @db.Date
  canceledReason        String?  @map("canceled_reason") @db.VarChar(255)
  skippedReason         String?  @map("skipped_reason") @db.VarChar(255)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                  Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientProtocolInstance PatientProtocolInstance   @relation(fields: [patientProtocolInstanceId], references: [id], onDelete: Cascade)
  procedureProtocol       ProcedureProtocol        @relation(fields: [procedureProtocolId], references: [id], onDelete: Restrict)
  appointment             Appointment?             @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@unique([patientProtocolInstanceId, sessionSequence], map: "uq_protocol_session_appointments_instance_sequence")
  @@index([tenantId], map: "idx_protocol_session_appointments_tenant_id")
  @@index([patientProtocolInstanceId], map: "idx_protocol_session_appointments_patient_protocol_instance_id")
  @@index([procedureProtocolId], map: "idx_protocol_session_appointments_procedure_protocol_id")
  @@index([status], map: "idx_protocol_session_appointments_status")
  @@map("protocol_session_appointments")
}

// ---------------------------------------------------------------------------
// Commercial Webhook Deduplication
// ---------------------------------------------------------------------------

model CommercialWebhookEvent {
  id              String   @id @default(uuid()) @db.Uuid
  providerEventId String   @map("provider_event_id") @db.VarChar(120)
  eventType       String   @map("event_type") @db.VarChar(80)
  processedAt     DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([providerEventId], map: "uq_commercial_webhook_events_provider_event_id")
  @@index([createdAt], map: "idx_commercial_webhook_events_created_at")
  @@map("commercial_webhook_events")
}
