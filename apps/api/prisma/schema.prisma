generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum CommercialOnboardingStatus {
  INITIATED
  AWAITING_PAYMENT
  PAID
  ONBOARDING_STARTED
  ONBOARDING_COMPLETED
  EXPIRED
  ESCALATED_TO_STAFF
}

enum MessagingChannel {
  WHATSAPP
}

enum IntegrationProvider {
  WHATSAPP_MOCK
  WHATSAPP_META
}

enum IntegrationConnectionStatus {
  ACTIVE
  INACTIVE
}

enum MessageThreadStatus {
  OPEN
  IN_HANDOFF
  CLOSED
}

enum MessageEventDirection {
  INBOUND
  OUTBOUND
  SYSTEM
}

enum MessageEventType {
  THREAD_CREATED
  MESSAGE_RECEIVED
  MESSAGE_SENT
  MESSAGE_SEND_FAILED
  HANDOFF_OPENED
  HANDOFF_ASSIGNED
  HANDOFF_CLOSED
  THREAD_PATIENT_LINKED
  THREAD_RESOLVED
}

enum MessageThreadResolutionActorType {
  HUMAN
  AUTOMATION
}

enum AppointmentFollowUpKind {
  APPOINTMENT_REMINDER_24H
}

enum AppointmentFollowUpDispatchStatus {
  PROCESSING
  SENT
  FAILED
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum HandoffStatus {
  OPEN
  ASSIGNED
  CLOSED
}

enum HandoffSource {
  MANUAL
  AUTOMATIC
}

enum HandoffPriority {
  HIGH
  MEDIUM
  LOW
}

enum AgentKind {
  CAPTACAO
  AGENDAMENTO
}

enum AgentExecutionStatus {
  WAITING_FOR_INPUT
  WAITING_FOR_SLOT_SELECTION
  HANDOFF_OPENED
  COMPLETED
  FAILED
}

enum UserStatus {
  INVITED
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum RoleCode {
  SUPER_ADMIN
  PLATFORM_ADMIN
  TENANT_ADMIN
  CLINIC_MANAGER
  RECEPTION
  PROFESSIONAL
}

enum PatientContactType {
  PHONE
  WHATSAPP
}

enum ScheduleDayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum SlotHoldStatus {
  ACTIVE
  CONSUMED
  CANCELED
  EXPIRED
}

enum AppointmentStatus {
  BOOKED
  CONFIRMED
  CHECKED_IN
  CALLED
  IN_PROGRESS
  AWAITING_CLOSURE
  AWAITING_PAYMENT
  RESCHEDULED
  CANCELED
  COMPLETED
  NO_SHOW
}

enum WaitlistStatus {
  OPEN
  CONTACTED
  CONVERTED
  CANCELED
}

enum ProtocolSessionStatus {
  PLANNED
  SCHEDULED
  COMPLETED
  CANCELED
  SKIPPED
}

enum PatientProtocolStatus {
  ACTIVE
  COMPLETED
  ABANDONED
  CANCELED
}

enum AestheticArea {
  FACIAL
  CORPORAL
  CAPILAR
  LASER
  HARMONIZACAO_OROFACIAL
  PEELING
  OUTRO
}

enum InvasivenessLevel {
  NON_INVASIVE
  MINIMALLY_INVASIVE
  MODERATELY_INVASIVE
  HIGHLY_INVASIVE
  SURGICAL
}

model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  slug      String       @unique @db.VarChar(100)
  name      String       @db.VarChar(160)
  status    TenantStatus @default(ACTIVE)
  timezone  String       @default("America/Sao_Paulo") @db.VarChar(64)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  subscriptions  Subscription[]
  tenantFeatures TenantFeature[]
  tenantSettings TenantSetting[]
  clinic         Clinic?
  units          Unit[]
  specialties    Specialty[]
  professionals  Professional[]
  consultationTypes        ConsultationType[]
  professionalSpecialties  ProfessionalSpecialty[]
  professionalUnits        ProfessionalUnit[]
  patients                 Patient[]
  patientContacts          PatientContact[]
  professionalSchedules    ProfessionalSchedule[]
  scheduleBlocks           ScheduleBlock[]
  slotHolds                SlotHold[]
  appointments             Appointment[]
  appointmentStatusHistory AppointmentStatusHistory[]
  waitlistEntries          Waitlist[]
  userRoles      UserRole[]
  auditLogs      AuditLog[]
  integrationConnections IntegrationConnection[]
  messageTemplates       MessageTemplate[]
  messageThreads         MessageThread[]
  messageEvents          MessageEvent[]
  webhookEvents          WebhookEvent[]
  handoffRequests        HandoffRequest[]
  procedureProtocols     ProcedureProtocol[]
  patientProtocolInstances PatientProtocolInstance[]
  protocolSessionAppointments ProtocolSessionAppointment[]

  @@map("tenants")
}

model User {
  id                     String     @id @default(uuid()) @db.Uuid
  email                  String     @unique @db.VarChar(180)
  fullName               String     @map("full_name") @db.VarChar(160)
  passwordHash           String     @map("password_hash") @db.VarChar(255)
  passwordChangedAt      DateTime?  @map("password_changed_at") @db.Timestamptz(6)
  passwordResetTokenHash String?    @map("password_reset_token_hash") @db.VarChar(255)
  passwordResetExpiresAt DateTime?  @map("password_reset_expires_at") @db.Timestamptz(6)
  sessionVersion         Int        @default(0) @map("session_version")
  status                 UserStatus @default(INVITED)
  createdAt              DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  userRoles        UserRole[]
  auditLogsAsActor AuditLog[] @relation("audit_actor_logs")
  slotHoldsCreated SlotHold[] @relation("slot_holds_created_by")
  appointmentsCreated Appointment[] @relation("appointments_created_by")
  appointmentsUpdated Appointment[] @relation("appointments_updated_by")
  appointmentStatusChanges AppointmentStatusHistory[] @relation("appointment_status_changed_by")
  professionalProfile Professional?
  messageEvents       MessageEvent[]   @relation("message_events_actor_user")
  handoffRequestsOpened HandoffRequest[] @relation("handoff_opened_by")
  handoffRequestsAssigned HandoffRequest[] @relation("handoff_assigned_to")
  handoffRequestsClosed HandoffRequest[] @relation("handoff_closed_by")

  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        RoleCode @unique
  name        String   @db.VarChar(120)
  description String?  @db.VarChar(255)
  isSystem    Boolean  @default(true) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  tenantId  String?  @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Restrict)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, tenantId], map: "uq_user_roles_user_role_tenant")
  @@index([userId], map: "idx_user_roles_user_id")
  @@index([roleId], map: "idx_user_roles_role_id")
  @@index([tenantId], map: "idx_user_roles_tenant_id")
  @@map("user_roles")
}

model Plan {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(120)
  description String?  @db.VarChar(255)
  priceCents  Int      @default(0) @map("price_cents")
  currency    String   @default("BRL") @db.VarChar(3)
  isPublic    Boolean  @default(false) @map("is_public")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  subscriptions Subscription[]
  commercialOnboardings CommercialOnboarding[]

  @@map("plans")
}

model CommercialOnboarding {
  id                  String                     @id @default(uuid()) @db.Uuid
  publicTokenHash     String                     @unique @map("public_token_hash") @db.VarChar(255)
  status              CommercialOnboardingStatus @default(INITIATED)
  planId              String                     @map("plan_id") @db.Uuid
  expiresAt           DateTime                   @map("expires_at") @db.Timestamptz(6)
  clinicDisplayName   String?                    @map("clinic_display_name") @db.VarChar(160)
  clinicLegalName     String?                    @map("clinic_legal_name") @db.VarChar(180)
  clinicDocumentNumber String?                   @map("clinic_document_number") @db.VarChar(40)
  clinicContactEmail  String?                    @map("clinic_contact_email") @db.VarChar(180)
  clinicContactPhone  String?                    @map("clinic_contact_phone") @db.VarChar(40)
  timezone            String?                    @db.VarChar(64)
  initialUnitName     String?                    @map("initial_unit_name") @db.VarChar(160)
  adminFullName       String?                    @map("admin_full_name") @db.VarChar(160)
  adminEmail          String?                    @map("admin_email") @db.VarChar(180)
  adminPasswordHash   String?                    @map("admin_password_hash") @db.VarChar(255)
  paymentReference    String?                    @map("payment_reference") @db.VarChar(120)
  checkoutConfirmedAt DateTime?                  @map("checkout_confirmed_at") @db.Timestamptz(6)
  onboardingStartedAt DateTime?                  @map("onboarding_started_at") @db.Timestamptz(6)
  onboardingCompletedAt DateTime?                @map("onboarding_completed_at") @db.Timestamptz(6)
  tenantId            String?                    @map("tenant_id") @db.Uuid
  clinicId            String?                    @map("clinic_id") @db.Uuid
  unitId              String?                    @map("unit_id") @db.Uuid
  adminUserId         String?                    @map("admin_user_id") @db.Uuid
  subscriptionId      String?                    @map("subscription_id") @db.Uuid
  createdAt           DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  plan Plan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([planId], map: "idx_commercial_onboardings_plan_id")
  @@index([status], map: "idx_commercial_onboardings_status")
  @@index([expiresAt], map: "idx_commercial_onboardings_expires_at")
  @@index([adminEmail], map: "idx_commercial_onboardings_admin_email")
  @@index([clinicContactEmail], map: "idx_commercial_onboardings_clinic_contact_email")
  @@index([tenantId], map: "idx_commercial_onboardings_tenant_id")
  @@map("commercial_onboardings")
}

model Subscription {
  id        String             @id @default(uuid()) @db.Uuid
  tenantId  String             @map("tenant_id") @db.Uuid
  planId    String             @map("plan_id") @db.Uuid
  status    SubscriptionStatus @default(TRIAL)
  startsAt  DateTime           @default(now()) @map("starts_at") @db.Timestamptz(6)
  endsAt    DateTime?          @map("ends_at") @db.Timestamptz(6)
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([tenantId], map: "idx_subscriptions_tenant_id")
  @@index([planId], map: "idx_subscriptions_plan_id")
  @@map("subscriptions")
}

model TenantFeature {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  key       String   @db.VarChar(120)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key], map: "uq_tenant_features_tenant_key")
  @@index([tenantId], map: "idx_tenant_features_tenant_id")
  @@map("tenant_features")
}

model TenantSetting {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  key       String   @db.VarChar(120)
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key], map: "uq_tenant_settings_tenant_key")
  @@index([tenantId], map: "idx_tenant_settings_tenant_id")
  @@map("tenant_settings")
}

model Clinic {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @unique @map("tenant_id") @db.Uuid
  displayName    String   @map("display_name") @db.VarChar(160)
  legalName      String?  @map("legal_name") @db.VarChar(180)
  documentNumber String?  @map("document_number") @db.VarChar(40)
  contactEmail   String?  @map("contact_email") @db.VarChar(180)
  contactPhone   String?  @map("contact_phone") @db.VarChar(40)
  timezone       String   @default("America/Sao_Paulo") @db.VarChar(64)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "idx_clinics_tenant_id")
  @@map("clinics")
}

model Unit {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(160)
  description String?  @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professionalUnits ProfessionalUnit[]
  professionalSchedules ProfessionalSchedule[]
  scheduleBlocks         ScheduleBlock[]
  slotHolds              SlotHold[]
  appointments           Appointment[]
  waitlistEntries        Waitlist[]

  @@unique([tenantId, name], map: "uq_units_tenant_name")
  @@index([tenantId], map: "idx_units_tenant_id")
  @@map("units")
}

model Specialty {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(160)
  description String?  @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professionalSpecialties ProfessionalSpecialty[]

  @@unique([tenantId, name], map: "uq_specialties_tenant_name")
  @@index([tenantId], map: "idx_specialties_tenant_id")
  @@map("specialties")
}

model Professional {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  userId                String?  @unique @map("user_id") @db.Uuid
  fullName              String   @map("full_name") @db.VarChar(160)
  displayName           String   @map("display_name") @db.VarChar(120)
  professionalRegister  String   @map("professional_register") @db.VarChar(80)
  visibleForSelfBooking Boolean  @default(false) @map("visible_for_self_booking")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                   User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  professionalSpecialties ProfessionalSpecialty[]
  professionalUnits       ProfessionalUnit[]
  schedules               ProfessionalSchedule[]
  scheduleBlocks          ScheduleBlock[]
  slotHolds               SlotHold[]
  appointments            Appointment[]
  waitlistEntries         Waitlist[]

  @@unique([tenantId, professionalRegister], map: "uq_professionals_tenant_register")
  @@index([tenantId], map: "idx_professionals_tenant_id")
  @@index([userId], map: "idx_professionals_user_id")
  @@map("professionals")
}

model ProfessionalSpecialty {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  professionalId String   @map("professional_id") @db.Uuid
  specialtyId    String   @map("specialty_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  specialty    Specialty    @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@unique([professionalId, specialtyId], map: "uq_professional_specialties_professional_specialty")
  @@index([tenantId], map: "idx_professional_specialties_tenant_id")
  @@index([professionalId], map: "idx_professional_specialties_professional_id")
  @@index([specialtyId], map: "idx_professional_specialties_specialty_id")
  @@map("professional_specialties")
}

model ProfessionalUnit {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  professionalId String   @map("professional_id") @db.Uuid
  unitId         String   @map("unit_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  unit         Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([professionalId, unitId], map: "uq_professional_units_professional_unit")
  @@index([tenantId], map: "idx_professional_units_tenant_id")
  @@index([professionalId], map: "idx_professional_units_professional_id")
  @@index([unitId], map: "idx_professional_units_unit_id")
  @@map("professional_units")
}

model ConsultationType {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  name                String   @db.VarChar(160)
  durationMinutes     Int      @map("duration_minutes")
  bufferBeforeMinutes Int      @default(0) @map("buffer_before_minutes")
  bufferAfterMinutes  Int      @default(0) @map("buffer_after_minutes")
  isFirstVisit        Boolean  @default(false) @map("is_first_visit")
  isReturnVisit       Boolean  @default(false) @map("is_return_visit")
  isOnline            Boolean  @default(false) @map("is_online")
  isActive            Boolean  @default(true) @map("is_active")
  aestheticArea       AestheticArea? @map("aesthetic_area")
  invasivenessLevel   InvasivenessLevel? @map("invasiveness_level")
  recoveryDays        Int?     @map("recovery_days")
  recommendedFrequencyDays Int? @map("recommended_frequency_days")
  preparationNotes    String?  @map("preparation_notes") @db.Text
  contraindications   String?  @db.Text
  aftercareGuidance   String?  @map("aftercare_guidance") @db.Text
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slotHolds     SlotHold[]
  appointments  Appointment[]
  waitlistEntries Waitlist[]
  procedureProtocols ProcedureProtocol[]

  @@unique([tenantId, name], map: "uq_consultation_types_tenant_name")
  @@index([tenantId], map: "idx_consultation_types_tenant_id")
  @@map("consultation_types")
}

model Patient {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  fullName       String?  @map("full_name") @db.VarChar(160)
  birthDate      DateTime? @map("birth_date") @db.Date
  documentNumber String?  @map("document_number") @db.VarChar(40)
  notes          String?  @db.Text
  intentHistory  Json?    @map("intent_history") // Sprint 8: Memory Context
  isActive       Boolean  @default(true) @map("is_active")
  mergedIntoPatientId String? @map("merged_into_patient_id") @db.Uuid
  mergedAt       DateTime? @map("merged_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mergedIntoPatient Patient? @relation("patient_merges", fields: [mergedIntoPatientId], references: [id], onDelete: SetNull)
  mergedPatients    Patient[] @relation("patient_merges")
  contacts          PatientContact[]
  slotHolds         SlotHold[]
  appointments      Appointment[]
  waitlistEntries   Waitlist[]
  messageThreads    MessageThread[]
  messageEvents     MessageEvent[]
  patientProtocolInstances PatientProtocolInstance[]

  @@index([tenantId], map: "idx_patients_tenant_id")
  @@index([mergedIntoPatientId], map: "idx_patients_merged_into_patient_id")
  @@map("patients")
}

model IntegrationConnection {
  id                    String                      @id @default(uuid()) @db.Uuid
  tenantId              String                      @map("tenant_id") @db.Uuid
  channel               MessagingChannel
  provider              IntegrationProvider
  status                IntegrationConnectionStatus @default(ACTIVE)
  displayName           String                      @map("display_name") @db.VarChar(120)
  phoneNumber           String?                     @map("phone_number") @db.VarChar(40)
  normalizedPhoneNumber String?                     @map("normalized_phone_number") @db.VarChar(40)
  externalAccountId     String?                     @map("external_account_id") @db.VarChar(120)
  webhookVerifyTokenHash String?                    @map("webhook_verify_token_hash") @db.VarChar(255)
  config                Json?
  createdAt             DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  threads       MessageThread[]
  messageEvents MessageEvent[]
  webhookEvents WebhookEvent[]

  @@index([tenantId], map: "idx_integration_connections_tenant_id")
  @@index([status], map: "idx_integration_connections_status")
  @@unique([tenantId, channel], map: "uq_integration_connections_tenant_channel")
  @@unique([tenantId, channel, displayName], map: "uq_integration_connections_tenant_channel_display_name")
  @@unique([channel, externalAccountId], map: "uq_integration_connections_channel_external_account_id")
  @@map("integration_connections")
}

model MessageTemplate {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  channel   MessagingChannel
  code      String           @db.VarChar(80)
  name      String           @db.VarChar(120)
  bodyText  String           @map("body_text") @db.Text
  variables Json?
  isActive  Boolean          @default(true) @map("is_active")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

