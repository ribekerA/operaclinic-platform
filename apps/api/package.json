{
  "name": "@operaclinic/api",
  "version": "0.1.0",
  "private": true,
  "description": "OperaClinic backend for aesthetic clinic operations with NestJS and Prisma-ready structure.",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "nest start --watch",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "api:ready:check": "powershell -ExecutionPolicy Bypass -File ../../scripts/check-api-readiness.ps1 -BaseUrl http://localhost:3001",
    "api:ready:strict": "powershell -ExecutionPolicy Bypass -File ../../scripts/check-api-readiness.ps1 -BaseUrl http://localhost:3001 -RequireHealthy",
    "agent:gate:run": "powershell -ExecutionPolicy Bypass -File ../../scripts/run-agent-gate.ps1 -BaseUrl http://localhost:3001 -IntervalMinutes 15 -DurationHours 0 -FailureRateThreshold 0.05 -P95ThresholdMs 1500 -MinSnapshots 3 -Environment local-runtime -OutputCsv tmp/agent-readiness-local-runtime.csv -OutputReport tmp/agent-gate-local-runtime.md -ValidationDoc ../../tmp/AGENT_GATE_LOCAL_VALIDATION.md",
    "agent:gate:run:cwd": "powershell -ExecutionPolicy Bypass -File ../../scripts/run-agent-gate.ps1 -BaseUrl http://localhost:3001 -IntervalMinutes 15 -DurationHours 0 -FailureRateThreshold 0.05 -P95ThresholdMs 1500 -MinSnapshots 3 -Environment local-runtime-cwd -OutputCsv tmp/agent-readiness-local-cwd.csv -OutputReport tmp/agent-gate-local-cwd.md -ValidationDoc ../../tmp/AGENT_GATE_LOCAL_VALIDATION.md",
    "agent:gate:evaluate": "powershell -ExecutionPolicy Bypass -File ../../scripts/evaluate-agent-gate.ps1 -InputCsv agent-readiness-staging-5pct.csv -FailureRateThreshold 0.05 -P95ThresholdMs 1500 -MinSnapshots 3 -OutputMarkdown agent-gate-report-staging-5pct.md",
    "clean": "rimraf dist",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset",
    "prisma:seed": "prisma db seed",
    "smoke:e2e:seed": "ts-node prisma/seed-smoke-e2e.ts",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/websockets": "^11.1.17",
    "@operaclinic/shared": "workspace:*",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "stripe": "^16.9.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "prisma": "^6.6.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
