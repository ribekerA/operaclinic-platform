{
  "name": "@operaclinic/api",
  "version": "0.1.0",
  "private": true,
  "description": "OperaClinic backend for aesthetic clinic operations with NestJS and Prisma-ready structure.",
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "api:ready:check": "node ../../scripts/check-api-readiness.mjs --base-url http://localhost:3001",
    "api:ready:strict": "node ../../scripts/check-api-readiness.mjs --base-url http://localhost:3001 --require-healthy",
    "agent:gate:run": "node ../../scripts/run-agent-gate.mjs --base-url http://localhost:3001 --interval-minutes 15 --duration-hours 0 --failure-rate-threshold 0.05 --p95-threshold-ms 1500 --min-snapshots 3 --environment local-runtime --output-csv tmp/agent-readiness-local-runtime.csv --output-report tmp/agent-gate-local-runtime.md --validation-doc ../../tmp/AGENT_GATE_LOCAL_VALIDATION.md",
    "agent:gate:run:cwd": "node ../../scripts/run-agent-gate.mjs --base-url http://localhost:3001 --interval-minutes 15 --duration-hours 0 --failure-rate-threshold 0.05 --p95-threshold-ms 1500 --min-snapshots 3 --environment local-runtime-cwd --output-csv tmp/agent-readiness-local-cwd.csv --output-report tmp/agent-gate-local-cwd.md --validation-doc ../../tmp/AGENT_GATE_LOCAL_VALIDATION.md",
    "agent:gate:evaluate": "node ../../scripts/evaluate-agent-gate.mjs --input-csv agent-readiness-staging-5pct.csv --failure-rate-threshold 0.05 --p95-threshold-ms 1500 --min-snapshots 3 --output-markdown agent-gate-report-staging-5pct.md",
    "clean": "rimraf dist",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset",
    "prisma:seed": "prisma db seed",
    "smoke:e2e:seed": "ts-node prisma/seed-smoke-e2e.ts",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.17",
    "@operaclinic/shared": "workspace:*",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "helmet": "^8.2.0",
    "prisma": "^6.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "stripe": "^16.9.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
