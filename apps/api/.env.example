NODE_ENV=development
APP_NAME=OperaClinic API
API_PORT=3001
API_PREFIX=api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/operaclinic?schema=public
# Prisma Accelerate (production/staging): prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY

# === Supabase (Auth) ===
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Use strong, different secrets. Production rejects placeholder or short values.
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret-of-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret-of-at-least-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COMMERCIAL_ONBOARDING_TTL_HOURS=48
# Enable only for local development when you intentionally want mock checkout.
COMMERCIAL_ONBOARDING_ENABLE_MOCK_CHECKOUT=false
PAYMENT_PROVIDER=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
WEB_URL=http://localhost:3000
BILLING_DUNNING_SCHEDULER_ENABLED=true
BILLING_DUNNING_SCHEDULER_HOUR_UTC=9
MESSAGING_WHATSAPP_META_ENABLED=false
MESSAGING_WHATSAPP_META_API_BASE_URL=https://graph.facebook.com
MESSAGING_WHATSAPP_META_API_VERSION=v21.0
MESSAGING_WHATSAPP_META_ACCESS_TOKEN=
MESSAGING_WHATSAPP_META_APP_SECRET=
# Meta Embedded Signup — obtenha em developers.facebook.com > Seu App > Configurações
# META_APP_ID: App ID do aplicativo Meta (mesmo que NEXT_PUBLIC_META_APP_ID no frontend)
# META_EMBEDDED_SIGNUP_CONFIG_ID: ID de configuração criado no fluxo de Embedded Signup
META_APP_ID=
META_EMBEDDED_SIGNUP_CONFIG_ID=

# Seed defaults
SEED_SUPER_ADMIN_EMAIL=superadmin@operaclinic.local
SEED_SUPER_ADMIN_NAME=OperaClinic Super Admin
# Set either SEED_SUPER_ADMIN_PASSWORD or SEED_SUPER_ADMIN_PASSWORD_HASH before seeding.
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_SUPER_ADMIN_PASSWORD_HASH=
SEED_BASE_PLAN_CODE=BASE_MVP
SEED_BASE_PLAN_NAME=Base MVP
SEED_BASE_PLAN_DESCRIPTION=Initial base plan for early tenant onboarding.
SEED_BASE_PLAN_PRICE_CENTS=0

# === Follow-ups / Cron ===
# Secret used to authenticate the cron endpoint (POST /appointment-follow-ups/trigger).
# Must match the Authorization: Bearer <secret> header sent by your scheduler.
CRON_SECRET=replace-with-a-strong-cron-secret-of-at-least-32-characters

# === Rate limiting ===
# Requests per minute per IP for public/unauthenticated routes.
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60

# === Agent layer ===
AGENT_LAYER_ENABLED=true
AGENT_LAYER_ROLLOUT_PERCENTAGE=100
AGENT_METRICS_WINDOW_MINUTES=15
AGENT_SKILL_FAILURE_RATE_ALERT_THRESHOLD=0.05
AGENT_SKILL_P95_ALERT_MS=1500

# === Agent API (external scheduling API for WhatsApp agent) ===
# Generate key: openssl rand -base64 32
AGENT_API_KEY=<gere com: openssl rand -base64 32>
# UUID do tenant da clínica que este agente representa
AGENT_API_TENANT_ID=<uuid-do-tenant>

# === WhatsApp gateway ===
# Provedor ativo: mock | evolution | meta
WHATSAPP_PROVIDER=mock
# Evolution API (QR code / local dev)
EVOLUTION_API_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=
