NODE_ENV=development
APP_NAME=OperaClinic API
API_PORT=3001
API_PREFIX=api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/operaclinic?schema=public
# Prisma Accelerate (production/staging): prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY

# === Supabase (Auth) ===
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Use strong, different secrets. Production rejects placeholder or short values.
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret-of-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret-of-at-least-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COMMERCIAL_ONBOARDING_TTL_HOURS=48
# Enable only for local development when you intentionally want mock checkout.
COMMERCIAL_ONBOARDING_ENABLE_MOCK_CHECKOUT=false
PAYMENT_PROVIDER=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
WEB_URL=http://localhost:3000
BILLING_DUNNING_SCHEDULER_ENABLED=true
BILLING_DUNNING_SCHEDULER_HOUR_UTC=9
MESSAGING_WHATSAPP_META_ENABLED=false
MESSAGING_WHATSAPP_META_API_BASE_URL=https://graph.facebook.com
MESSAGING_WHATSAPP_META_API_VERSION=v21.0
MESSAGING_WHATSAPP_META_ACCESS_TOKEN=
MESSAGING_WHATSAPP_META_APP_SECRET=

# Seed defaults
SEED_SUPER_ADMIN_EMAIL=superadmin@operaclinic.local
SEED_SUPER_ADMIN_NAME=OperaClinic Super Admin
# Set either SEED_SUPER_ADMIN_PASSWORD or SEED_SUPER_ADMIN_PASSWORD_HASH before seeding.
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_SUPER_ADMIN_PASSWORD_HASH=
SEED_BASE_PLAN_CODE=BASE_MVP
SEED_BASE_PLAN_NAME=Base MVP
SEED_BASE_PLAN_DESCRIPTION=Initial base plan for early tenant onboarding.
SEED_BASE_PLAN_PRICE_CENTS=0
