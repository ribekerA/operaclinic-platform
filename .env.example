# App
NODE_ENV=development
APP_NAME=OperaClinic API

# API
API_PORT=3001
API_PREFIX=api/v1
# Local development: use your PostgreSQL connection string.
# Production: use the managed PostgreSQL connection string from your provider.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/operaclinic?schema=public
# Use strong, different secrets. Production rejects placeholder or short values.
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Web
# Required by the Next.js session proxy. Use https in production; no runtime fallback is used.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# Seed
SEED_SUPER_ADMIN_EMAIL=superadmin@operaclinic.local
SEED_SUPER_ADMIN_NAME=OperaClinic Super Admin
# Set either SEED_SUPER_ADMIN_PASSWORD or SEED_SUPER_ADMIN_PASSWORD_HASH before seeding.
SEED_SUPER_ADMIN_PASSWORD=ChangeThis123!
SEED_SUPER_ADMIN_PASSWORD_HASH=
SEED_BASE_PLAN_CODE=BASE_MVP
SEED_BASE_PLAN_NAME=Base MVP
SEED_BASE_PLAN_DESCRIPTION=Initial base plan for early tenant onboarding.
SEED_BASE_PLAN_PRICE_CENTS=0

# =============================================================================
# COMMERCIAL / PAYMENT INTEGRATION
# =============================================================================

# Stripe API Key (Secret Key from https://dashboard.stripe.com/apikeys)
# Format: sk_test_... (test mode) or sk_live_... (production)
STRIPE_SECRET_KEY=sk_test_placeholder

# Stripe Webhook Secret (from https://dashboard.stripe.com/webhooks)
# Create endpoint: POST https://your-domain.com/api/v1/commercial/webhook/payment
# Example: whsec_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_placeholder

# Commercial onboarding TTL (Time To Live) in hours
# How long public tokens remain valid for registration (default: 48)
COMMERCIAL_ONBOARDING_TTL_HOURS=48

# Payment provider for development/testing (optional)
# Values: "mock" (simulates payments) or "stripe" (actual Stripe)
# If not set: uses "stripe" in production, "stripe" if STRIPE_SECRET_KEY set, else "mock"
# PAYMENT_PROVIDER=mock

# Redirect URL after successful checkout (used by Stripe adapter)
WEB_URL=http://localhost:3000

# Agent Layer rollout controls
# AGENT_LAYER_ENABLED=false disables all automatic agent triggering from inbound messaging.
AGENT_LAYER_ENABLED=true
# Percentage of threads eligible for agent execution (0-100).
AGENT_LAYER_ROLLOUT_PERCENTAGE=100
# Observability window for agent skill metrics in health readiness.
AGENT_METRICS_WINDOW_MINUTES=15
# Alert threshold (0-1) for failed skills inside metrics window.
AGENT_SKILL_FAILURE_RATE_ALERT_THRESHOLD=0.05
# Alert threshold in milliseconds for skill p95 latency.
AGENT_SKILL_P95_ALERT_MS=1500

